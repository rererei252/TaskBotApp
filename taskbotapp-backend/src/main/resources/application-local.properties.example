# Local profile settings (Gmail SMTP / fully free setup)

spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=YOUR_GMAIL_ADDRESS
spring.mail.password=YOUR_GOOGLE_APP_PASSWORD_16_CHARS
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true

app.auth.mail-from=YOUR_GMAIL_ADDRESS
app.auth.verify-base-url=http://localhost:5173/auth/verify
app.auth.verification-expire-hours=24

# OpenAI
app.ai.openai.api-key=YOUR_OPENAI_API_KEY
app.ai.openai.model=gpt-5-mini
app.ai.openai.base-url=https://api.openai.com/v1
app.ai.recommendation-window-days=14
